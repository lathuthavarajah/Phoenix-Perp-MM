# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
WALLET_KEYPAIR_PATH=~/.config/solana/id.json

# Engine config
USE_DEVNET=true
FUNDING_ENTRY_THRESHOLD_APY=0.15
FUNDING_EXIT_THRESHOLD_APY=0.02
POSITION_SIZE_USDC=500
MAX_LEVERAGE=3
REBALANCE_DELTA_THRESHOLD=0.01
MARGIN_WARNING_RATIO=0.25
EMERGENCY_CLOSE_RATIO=0.12
ENGINE_HTTP_PORT=8080

# Dashboard
NEXT_PUBLIC_ENGINE_URL=http://localhost:8080
